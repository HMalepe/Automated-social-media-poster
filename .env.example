# Copy to `.env` and fill in what you need.
# Local testing works with zero keys: offline templates + dry-run mode.

# --- AI (optional — offline templates used when unset) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- X / Twitter ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- LinkedIn ---
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=          # e.g. urn:li:person:AbCdEf

# --- YouTube (Google Cloud OAuth refresh token) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=public # public | unlisted | private
YOUTUBE_CATEGORY_ID=22        # 22 = People & Blogs

# --- TikTok (Content Posting API) ---
TIKTOK_ACCESS_TOKEN=
TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE

# --- Pipeline behavior ---
PIPELINE_AUTO_APPROVE=false   # true = skip draft review
PIPELINE_DRY_RUN=true         # false = call real platform APIs

# --- Paths (optional overrides) ---
# PIPELINE_DATA_DIR=data
# PIPELINE_DRAFTS_DIR=drafts
# PIPELINE_QUEUE_FILE=data/content_queue.json
